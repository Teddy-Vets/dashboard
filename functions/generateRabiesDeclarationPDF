
import { createClientFromRequest } from 'npm:@base44/sdk@0.7.1';
import { jsPDF } from 'npm:jspdf@2.5.1';
import { hebrewFont } from './helpers/pdfHelpers.js'; // Assuming you have a helper for the font

function setupHebrewFont(doc) {
    doc.addFileToVFS('Amiri-Regular.ttf', hebrewFont);
    doc.addFont('Amiri-Regular.ttf', 'Amiri', 'normal');
    doc.setFont('Amiri');
    doc.setLanguage('he');
    return doc;
}

function writeHebrewText(doc, text, x, y, options = {}) {
    const { fontSize = 10, align = 'right', maxWidth = doc.internal.pageSize.getWidth() - 40, lineHeight = 7 } = options;
    doc.setFontSize(fontSize);
    if (typeof text !== 'string') text = String(text || '');
    
    const lines = doc.splitTextToSize(text, maxWidth);
    doc.text(lines, x, y, { align });
    return y + (lines.length * lineHeight);
}

function createPageHeader(doc, clinicName) {
    const pageWidth = doc.internal.pageSize.getWidth();
    doc.setFontSize(20);
    doc.text('הצהרת בעלים - חיסון כלבת', pageWidth / 2, 20, { align: 'center' });
    if (clinicName) {
        doc.setFontSize(12);
        doc.text(clinicName, pageWidth / 2, 28, { align: 'center' });
    }
    doc.setLineWidth(0.5);
    doc.line(20, 32, pageWidth - 20, 32);
    return 40;
}

function drawCheckbox(doc, x, y, checked) {
    doc.setDrawColor(0);
    doc.setLineWidth(0.3);
    doc.rect(x - 4, y - 3.5, 4, 4); // Box
    if (checked) {
        doc.text('X', x - 3, y); // Checkmark
    }
}

function writeDeclarationItem(doc, text, isChecked, x, y) {
    const pageHeight = doc.internal.pageSize.getHeight();
    if (y > pageHeight - 30) {
        doc.addPage();
        y = 20;
    }
    drawCheckbox(doc, x, y, isChecked);
    return writeHebrewText(doc, text, x - 7, y, { align: 'right' });
}

function formatHebrewDate(dateString) {
    if (!dateString) return 'לא צוין';
    try {
        const date = new Date(dateString);
        return `${date.getDate().toString().padStart(2, '0')}/${(date.getMonth() + 1).toString().padStart(2, '0')}/${date.getFullYear()}`;
    } catch {
        return dateString;
    }
}

Deno.serve(async (req) => {
    try {
        const base44 = createClientFromRequest(req);
        const user = await base44.auth.me();
        if (!user) return new Response(JSON.stringify({ error: 'Unauthorized' }), { status: 401 });

        const { declarationId } = await req.json();
        if (!declarationId) return new Response(JSON.stringify({ error: 'Missing declarationId' }), { status: 400 });

        const declarations = await base44.entities.RabiesDeclaration.filter({ id: declarationId });
        if (!declarations || declarations.length === 0) {
            return new Response(JSON.stringify({ error: 'Declaration not found' }), { status: 404 });
        }
        const declaration = declarations[0];

        let clinicName = 'מרפאות טדי וטס';
        if (declaration.clinic_id) {
            const clinics = await base44.entities.Clinic.filter({ id: declaration.clinic_id });
            if (clinics.length > 0) clinicName = clinics[0].name;
        }

        const doc = new jsPDF();
        setupHebrewFont(doc);
        const pageWidth = doc.internal.pageSize.getWidth();
        const pageRightX = pageWidth - 20;
        let y = createPageHeader(doc, clinicName);

        doc.setFontSize(12);
        y = writeHebrewText(doc, `תאריך הצהרה: ${formatHebrewDate(declaration.declaration_date)}`, pageRightX, y);
        y += 10;

        doc.setFontSize(14);
        y = writeHebrewText(doc, 'פרטי הבעלים:', pageRightX, y, { fontSize: 14 });
        y = writeHebrewText(doc, `שם: ${declaration.owner_name}`, pageRightX, y);
        y = writeHebrewText(doc, `ת.ז: ${declaration.owner_id_number}`, pageRightX, y);
        y = writeHebrewText(doc, `כתובת: ${declaration.owner_address}`, pageRightX, y);
        y += 10;

        doc.setFontSize(14);
        y = writeHebrewText(doc, 'פרטי הכלב:', pageRightX, y, { fontSize: 14 });
        y = writeHebrewText(doc, `שם: ${declaration.pet_name}`, pageRightX, y);
        y = writeHebrewText(doc, `שבב: ${declaration.pet_microchip}`, pageRightX, y);
        y += 10;

        doc.setFontSize(14);
        y = writeHebrewText(doc, 'הריני מצהיר כדלקמן:', pageRightX, y, { fontSize: 14 });
        y += 5;
        doc.setFontSize(10);
        y = writeDeclarationItem(doc, 'הכלב שברשותי הינו מעל גיל 3 חודשים.', declaration.dog_is_over_3_months, pageRightX, y);
        y = writeDeclarationItem(doc, 'אני הבעלים של הכלב שפרטיו רשומים מעלה.', declaration.is_owner_of_dog, pageRightX, y);
        y = writeDeclarationItem(doc, 'ידוע לי כי על פי חוק להסדרת הפיקוח על כלבים, התשס"ג 2002, חלה חובה לחסן כל כלב שגילו מעל 3 חודשים בחיסון נגד כלבת, לסמנו בשבב אלקטרוני וכן לשלם אגרת רישיון שנתית.', declaration.understands_rabies_law, pageRightX, y);
        y = writeDeclarationItem(doc, 'הוסברו לי תופעות הלוואי האפשריות לחיסון.', declaration.understands_side_effects, pageRightX, y);
        y = writeDeclarationItem(doc, 'ידוע לי כי על פי חוקי העזר העירוניים חלה עלי חובה לאסוף את צואת כלבי מרשות הרבים.', declaration.understands_feces_disposal, pageRightX, y);
        y += 15;

        if (declaration.status === 'signed' && declaration.owner_signature) {
             y = writeHebrewText(doc, 'חתום דיגיטלית', pageRightX, y);
             y = writeHebrewText(doc, `שם החותם: ${declaration.owner_name}`, pageRightX, y);
             y = writeHebrewText(doc, `תאריך חתימה: ${formatHebrewDate(declaration.signed_at)}`, pageRightX, y);
        } else {
             y = writeHebrewText(doc, '____________________', pageRightX, y);
             y = writeHebrewText(doc, 'חתימת הבעלים', pageRightX, y);
        }

        const pdfBytes = doc.output('arraybuffer');
        return new Response(pdfBytes, {
            status: 200,
            headers: { 'Content-Type': 'application/pdf' }
        });

    } catch (error) {
        console.error('Error generating Rabies Declaration PDF:', error);
        return new Response(JSON.stringify({ error: error.message }), { status: 500 });
    }
});
